rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user can only read/write their own data.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Legacy pre-auth flat collections. Read-only, and only for the
    // original account owner — used once by services/migration.ts to copy
    // her data into users/{uid}/... on first sign-in.
    match /transactions/{id} {
      allow read: if request.auth != null && request.auth.token.email == "anionce91@gmail.com";
      allow write: if false;
    }
    match /goals/{id} {
      allow read: if request.auth != null && request.auth.token.email == "anionce91@gmail.com";
      allow write: if false;
    }
    match /settings/{id} {
      allow read: if request.auth != null && request.auth.token.email == "anionce91@gmail.com";
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
